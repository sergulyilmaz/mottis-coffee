# ─────────────────────────────────────────────
# Mottis Coffee Backend — Environment Variables
# .env.example → kopyala → .env olarak kaydet
# ─────────────────────────────────────────────

# PostgreSQL bağlantısı
DATABASE_URL=postgresql://user:password@localhost:5432/mottis

# JWT
JWT_SECRET=mottis_super_secret_key_degistir
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=mottis_refresh_secret_degistir
JWT_REFRESH_EXPIRES_IN=30d

# Dinamik QR Token — HMAC anahtarı (en az 32 karakter)
QR_SECRET=mottis_qr_hmac_secret_degistir
# QR token geçerlilik süresi (saniye)
QR_TTL_SECONDS=60

# Sadakat — kaç pul = 1 ikram?
STAMPS_PER_REWARD=8

# Firebase Admin SDK (FCM push bildirimleri)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Sunucu
PORT=3000
NODE_ENV=development
